# ALEX IO V2 - ENVIRONMENT VARIABLES

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Supabase (Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# WhatsApp API (360Dialog or Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_secure_token

# AI Providers (At least one required)
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
DEEPSEEK_API_KEY=your_deepseek_key

# Optional: Redis (For scaling to 5000+ users)
REDIS_URL=redis://user:password@host:port

# --- 360Dialog (WhatsApp) ---
DIALOG360_API_URL=https://hub.360dialog.io/api/v2
DIALOG360_API_KEY=your_360dialog_key

# --- STRIPE (Pagos) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_yyy
STRIPE_PRICE_ENTERPRISE=price_zzz

# --- CRIPTO (Pagos) ---
BTC_WALLET=bc1q...
USDT_WALLET=TX...
ETH_WALLET=0x...

# --- FRONTEND URL ---
FRONTEND_URL=http://localhost:3001
